# social-intelligence/.env.example
# Copiar a .env y rellenar valores reales. Nunca subir .env a git.

# Base de datos MySQL (compartida, esquemas por medio)
DB_HOST=localhost
DB_PORT=3306
DB_USER=social_app
DB_PASSWORD=your_password_here
DB_NAME=social_intelligence

# Seguridad del panel
PANEL_USERNAME=admin
PANEL_PASSWORD=your_panel_password_here
JWT_SECRET=your_jwt_secret_32_chars_minimum
JWT_EXPIRE_HOURS=12

# Entorno
ENVIRONMENT=production
LOG_LEVEL=INFO
